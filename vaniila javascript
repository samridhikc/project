    async function loadExercises() { try { const list = await api('/exercises'); state.data.exercises = { list }; const el = document.getElementById('page-content'); if (el && state.page==='exercises') { el.innerHTML=renderExercises(); lucide.createIcons(); } } catch(err){} }


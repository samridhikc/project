      try {
        await api('/workouts','POST',{name:document.getElementById('wk-name').value,type:document.getElementById('wk-type').value,duration:parseInt(document.getElementById('wk-dur').value),calories:parseInt(document.getElementById('wk-cal').value)||0}); 

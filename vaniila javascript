    async function loadWorkoutData() { try { const list = await api('/workouts'); state.data.workouts = { list }; const el = document.getElementById('page-content'); if (el && state.page==='workouts') { el.innerHTML=renderWorkouts(); lucide.createIcons(); initWorkoutCharts(); } } catch(err){} }

    async function handleAddWorkout(e) { 

    async function handleAddGoal(e) { 
      e.preventDefault(); 
      try {
        await api('/goals','POST',{title:document.getElementById('goal-title').value,target:parseFloat(document.getElementById('goal-target').value),unit:document.getElementById('goal-unit').value,current:parseFloat(document.getElementById('goal-current').value)||0}); 

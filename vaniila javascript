      <div class="bg-white rounded-2xl p-6 shadow-sm border border-slate-100 mb-6">
        <h3 class="text-lg font-bold text-slate-900 mb-4">Create New Goal</h3>
        <form onsubmit="handleAddGoal(event)" class="grid sm:grid-cols-2 gap-3">

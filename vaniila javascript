    function googleStep2() {
      const email = document.getElementById('google-email').value.trim();
      if (!email || !email.includes('@')) {
        showToast('Please enter a valid email address', 'error');
        return;
      }
      state.googleUserData = { email };
      document.getElementById('google-email-display').textContent = email;
      document.getElementById('google-step-1').classList.add('hidden');
      document.getElementById('google-step-2').classList.remove('hidden');
    }

    function googleVerifyEmail() {
      const email = state.googleUserData?.email;
      if (!email) return;
      const code = generateVerificationCode(email);
      document.getElementById('google-step-2').classList.add('hidden');
      document.getElementById('google-step-3').classList.remove('hidden');
      document.getElementById('google-verify-email').textContent = email;
      document.getElementById('google-verify-code-display').textContent = `Demo code: ${code}`;
      showToast(`Verification code sent to ${email}`, 'info');
    }

    function resendGoogleCode() {
      const email = state.googleUserData?.email;
      if (!email) return;
      const code = generateVerificationCode(email);
      document.getElementById('google-verify-code-display').textContent = `Demo code: ${code}`;
      showToast(`New code sent to ${email}`, 'info');
    }

    function verifyGoogleCode() {
      const email = state.googleUserData?.email;
      const code = document.getElementById('google-verify-code').value.trim();
      if (!verifyCode(email, code)) {
        showToast('Invalid verification code', 'error');
        return;
      }
      // Simulate successful Google sign-in
      const name = email.split('@')[0].replace(/[._]/g, ' ').replace(/\b\w/g, l => l.toUpperCase());
      const user = { name, email, role: 'customer', subscription: { plan: 'free' } };
      setAuth('google-token-' + Date.now(), user);
      closeModal();
      showToast('Signed in with Google successfully!');
      render();
    }


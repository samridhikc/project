      localStorage.setItem('fh_user', JSON.stringify(user));
    }

    function logout() {
      state.token = null; state.user = null; state.page = 'dashboard'; state.data = {}; state.activeChatId = null;
      localStorage.removeItem('fh_token'); localStorage.removeItem('fh_user');
      render();
    }

    function navigate(page) { state.page = page; render(); }

    // ============================================================
    // CHART HELPERS
    // ============================================================
    function destroyChart(id) { if (chartInstances[id]) { chartInstances[id].destroy(); delete chartInstances[id]; } }
    function createChart(id, config) { destroyChart(id); const el = document.getElementById(id); if (!el) return null; chartInstances[id] = new Chart(el.getContext('2d'), config); return chartInstances[id]; }

    function initPageCharts() {
      const p = state.page;
      const isTrainer = state.user?.role === 'trainer';
      if (isTrainer) return;
      if (p === 'dashboard') initDashboardCharts();
      else if (p === 'calories') initCalorieCharts();
      else if (p === 'weight') initWeightChart();
      else if (p === 'workouts') initWorkoutCharts();
    }


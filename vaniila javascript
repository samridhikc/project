      createChart('weightChart', { type:'line', data:{ labels:h.map(w=>new Date(w.date).toLocaleDateString), datasets:[{ label:'Weight (kg)', data:h.map(w=>w.weight), borderColor:'#059669', backgroundColor:'rgba(5,150,105,0.1)', fill:true, tension:0.4, pointRadius:5, pointBackgroundColor:'#059669', pointBorderColor:'#fff', pointBorderWidth:2 }] }, options:{ responsive:true, plugins:{ legend:{ display:false } }, scales:{ y:{ grid:{color:'#f1f5f9'}, ticks:{font:{family:'Inter',size:11}} }, x:{ grid:{display:false}, ticks:{font:{family:'Inter',size:11}} } } } });
    }

    async function loadWeightData() { try { const history = await api('/weight/history'); state.data.weight = { history }; const el = document.getElementById('page-content'); if (el && state.page==='weight') { el.innerHTML=renderWeight(); lucide.createIcons(); initWeightChart(); } } catch(err){} }
    
    async function handleWeightLog(e) { 
      e.preventDefault(); 

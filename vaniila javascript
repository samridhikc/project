    // ============================================================
    function generateVerificationCode(email) {
      const code = Math.floor(100000 + Math.random() * 900000).toString();
      verificationCodes[email] = code;
      return code;
    }

    function verifyCode(email, code) {
      return verificationCodes[email] === code;
    }


              <div><label class="block text-sm font-medium text-slate-700 mb-1.5">Weight (kg)</label><input type="number" id="prof-weight" value="${u.weight||''}" step="0.1" class="w-full px-4 py-3 bg-white border border-slate-200 rounded-lg focus:ring-2 focus:ring-brand-500 outline-none"></div>
              <div><label class="block text-sm font-medium text-slate-700 mb-1.5">Height (cm)</label><input type="number" id="prof-height" value="${u.height||''}" class="w-full px-4 py-3 bg-white border border-slate-200 rounded-lg focus:ring-2 focus:ring-brand-500 outline-none"></div>
              <div><label class="block text-sm font-medium text-slate-700 mb-1.5">Fitness Goal</label><select id="prof-goal" class="w-full px-4 py-3 bg-white border border-slate-200 rounded-lg focus:ring-2 focus:ring-brand-500 outline-none"><option value="" ${!u.fitnessGoal?'selected':''}>Select...</option><option value="lose" ${u.fitnessGoal==='lose'?'selected':''}>Lose Weight</option><option value="maintain" ${u.fitnessGoal==='maintain'?'selected':''}>Maintain</option><option value="gain" ${u.fitnessGoal==='gain'?'selected':''}>Gain Muscle</option></select></div>
            </div>
            <button type="submit" class="bg-brand-600 hover:bg-brand-700 text-white px-8 py-3.5 rounded-lg font-semibold shadow-md transition-all">Save Profile</button>
          </form>
        </div>
      </div>`;
    }

    async function handleProfileUpdate(e) {
      e.preventDefault();
      const body = { name:document.getElementById('prof-name').value, age:parseInt(document.getElementById('prof-age').value)||undefined, gender:document.getElementById('prof-gender').value||undefined, weight:parseFloat(document.getElementById('prof-weight').value)||undefined, height:parseInt(document.getElementById('prof-height').value)||undefined, fitnessGoal:document.getElementById('prof-goal').value||undefined };
      try { const data = await api('/user/profile','PUT',body); state.user = { ...state.user, ...body }; localStorage.setItem('fh_user',JSON.stringify(state.user)); showToast('Profile updated!'); render(); } catch(err){}
    }

    // ============================================================
    // CALORIES (REDESIGNED - Meal Tracker)
    // ============================================================
    function renderCalories() {
      loadCalorieData();
      const d = state.data.calories || {};
      const log = d.todayLog || {meals:[], totalCalories:0};
      const totalCal = log.totalCalories || 0;
      const goalCal = 2200;
      const remaining = Math.max(0, goalCal - totalCal);
      const pct = Math.min(100, Math.round((totalCal/goalCal)*100));

      const mealTypes = [
        { key:'breakfast', label:'Breakfast', icon:'sunrise', color:'text-amber-500', bg:'bg-amber-50', border:'border-amber-100' },
        { key:'lunch', label:'Lunch', icon:'sun', color:'text-orange-500', bg:'bg-orange-50', border:'border-orange-100' },
        { key:'dinner', label:'Dinner', icon:'moon', color:'text-indigo-500', bg:'bg-indigo-50', border:'border-indigo-100' },
        { key:'snack', label:'Snack', icon:'cookie', color:'text-pink-500', bg:'bg-pink-50', border:'border-pink-100' }
      ];

      function getMealStats(mealType) {
        const items = (log.meals||[]).filter(m => m.mealType === mealType);
        return {
          calories: items.reduce((s,m)=>s+(m.calories||0),0),
          protein: items.reduce((s,m)=>s+(m.protein||0),0),
          carbs: items.reduce((s,m)=>s+(m.carbs||0),0),
          fat: items.reduce((s,m)=>s+(m.fat||0),0),
          items
        };
      }

      const totalProtein = (log.meals||[]).reduce((s,m)=>s+(m.protein||0),0);
      const totalCarbs = (log.meals||[]).reduce((s,m)=>s+(m.carbs||0),0);
      const totalFat = (log.meals||[]).reduce((s,m)=>s+(m.fat||0),0);

      return `
      <div class="mb-8">
        <div class="flex items-center justify-between">
          <div>
            <h1 class="text-3xl font-bold text-slate-900 tracking-tight">Today</h1>
            <p class="text-slate-500 mt-1">${new Date().toLocaleDateString('en-US',{weekday:'long',month:'long',day:'numeric'})}</p>
          </div>
          <button onclick="openAddRecipe()" class="flex items-center gap-2 bg-brand-600 hover:bg-brand-700 text-white px-4 py-2.5 rounded-xl font-semibold text-sm shadow-md transition-all">
            <i data-lucide="plus" class="w-4 h-4"></i> New Recipe
          </button>
        </div>
      </div>

      <!-- Daily Summary Bar -->
      <div class="bg-white rounded-2xl p-6 shadow-sm border border-slate-100 mb-6">
        <div class="flex items-center justify-between mb-3">
          <div>
            <span class="text-2xl font-extrabold text-slate-900">${totalCal.toLocaleString()}</span>
            <span class="text-sm text-slate-400 ml-1">/ ${goalCal.toLocaleString()} kcal</span>
          </div>
          <span class="text-sm font-semibold ${remaining > 0 ? 'text-brand-600' : 'text-red-500'}">${remaining > 0 ? remaining.toLocaleString() + ' remaining' : 'Over by ' + Math.abs(remaining).toLocaleString()}</span>
        </div>
        <div class="w-full h-3 bg-slate-100 rounded-full overflow-hidden mb-4">
          <div class="h-full bg-gradient-to-r ${pct > 90 ? 'from-yellow-500 to-orange-500' : 'from-brand-500 to-brand-600'} rounded-full progress-fill" style="width:${pct}%"></div>
        </div>
        <div class="grid grid-cols-3 gap-4 text-center">
          <div><p class="text-xs text-slate-400 uppercase tracking-wider font-semibold">Carbs</p><p class="text-lg font-bold text-blue-600">${totalCarbs}g</p></div>
          <div><p class="text-xs text-slate-400 uppercase tracking-wider font-semibold">Protein</p><p class="text-lg font-bold text-brand-600">${totalProtein}g</p></div>
          <div><p class="text-xs text-slate-400 uppercase tracking-wider font-semibold">Fat</p><p class="text-lg font-bold text-yellow-600">${totalFat}g</p></div>
        </div>
      </div>

      <!-- Meal Sections -->
      ${mealTypes.map(meal => {
        const stats = getMealStats(meal.key);
        return `
        <div class="meal-section bg-white rounded-2xl p-5 shadow-sm border border-slate-100 mb-4">
          <div class="flex items-center justify-between mb-3">
            <div class="flex items-center gap-3">
              <div class="w-10 h-10 ${meal.bg} ${meal.border} border rounded-xl flex items-center justify-center"><i data-lucide="${meal.icon}" class="w-5 h-5 ${meal.color}"></i></div>
              <div>
                <h3 class="font-bold text-slate-900">${meal.label}</h3>
                <p class="text-xs text-slate-400">${stats.calories} kcal</p>
              </div>
            </div>
            <button onclick="openFoodSearch('${meal.key}')" class="flex items-center gap-1.5 text-brand-600 hover:text-brand-700 font-semibold text-sm transition-all">
              <i data-lucide="plus-circle" class="w-4 h-4"></i> Add food
            </button>
          </div>
          <div class="grid grid-cols-3 gap-3 mb-3">
            <div class="text-center py-2 bg-blue-50 rounded-lg"><p class="text-[10px] text-blue-400 uppercase font-bold">Carbs</p><p class="text-sm font-bold text-blue-600">${stats.carbs}g</p></div>
            <div class="text-center py-2 bg-brand-50 rounded-lg"><p class="text-[10px] text-brand-400 uppercase font-bold">Protein</p><p class="text-sm font-bold text-brand-600">${stats.protein}g</p></div>
            <div class="text-center py-2 bg-yellow-50 rounded-lg"><p class="text-[10px] text-yellow-500 uppercase font-bold">Fat</p><p class="text-sm font-bold text-yellow-600">${stats.fat}g</p></div>
          </div>
          ${stats.items.length > 0 ? stats.items.map(item => `
            <div class="flex items-center justify-between py-2.5 px-3 bg-slate-50 rounded-xl mb-1.5">
              <div>
                <p class="text-sm font-medium text-slate-700">${item.name}</p>
                <p class="text-[10px] text-slate-400">C:${item.carbs||0}g · P:${item.protein||0}g · F:${item.fat||0}g</p>
              </div>
              <div class="flex items-center gap-3">
                <span class="text-sm font-bold text-slate-500">${item.calories}</span>
                <button onclick="removeMealItem('${meal.key}', '${item.name}')" class="text-slate-300 hover:text-red-500 transition-colors"><i data-lucide="x" class="w-4 h-4"></i></button>
              </div>
            </div>
          `).join('') : `<p class="text-xs text-slate-300 text-center py-2">No foods added yet</p>`}
        </div>`;
      }).join('')}

      <!-- Charts -->
      <div class="grid lg:grid-cols-2 gap-6 mt-6">
        <div class="bg-white rounded-2xl p-6 shadow-sm border border-slate-100"><h3 class="text-lg font-bold text-slate-900 mb-4">Weekly Calorie Trend</h3><canvas id="calorieTrendChart" height="200"></canvas></div>
        <div class="bg-white rounded-2xl p-6 shadow-sm border border-slate-100"><h3 class="text-lg font-bold text-slate-900 mb-4">Macros Split</h3><canvas id="macroChart" height="200"></canvas></div>
      </div>`;
    }

    function removeMealItem(mealType, foodName) {
      const log = state.data.calories?.todayLog || {meals:[], totalCalories:0};
      const idx = log.meals.findIndex(m => m.mealType === mealType && m.name === foodName);
      if (idx !== -1) {
        log.meals.splice(idx, 1);
        log.totalCalories = log.meals.reduce((s,m)=>s+m.calories,0);
        try { api('/calories/log','PUT', log.meals); } catch(e){}
        const el = document.getElementById('page-content');
        if (el && state.page==='calories') { el.innerHTML=renderCalories(); lucide.createIcons(); initCalorieCharts(); }
        showToast('Food removed');
      }
    }

    function initCalorieCharts() {
      createChart('calorieTrendChart', { type:'line', data:{ labels:['Mon','Tue','Wed','Thu','Fri','Sat','Sun'], datasets:[{ label:'Consumed', data:[1800,2100,1950,2200,1750,2300,1680], borderColor:'#059669', backgroundColor:'rgba(5,150,105,0.08)', fill:true, tension:0.4, pointRadius:4, pointBackgroundColor:'#059669' },{ label:'Goal', data:[2200,2200,2200,2200,2200,2200,2200], borderColor:'#e2e8f0', borderDash:[6,4], pointRadius:0, fill:false }] }, options:{ responsive:true, plugins:{ legend:{ position:'bottom', labels:{ usePointStyle:true, padding:16, font:{family:'Inter',size:12} } } }, scales:{ y:{ beginAtZero:false, grid:{color:'#f1f5f9'}, ticks:{font:{family:'Inter',size:11}} }, x:{ grid:{display:false}, ticks:{font:{family:'Inter',size:11}} } } } });
      const totalProtein = (state.data.calories?.todayLog?.meals||[]).reduce((s,m)=>s+(m.protein||0),0) || 35;
      const totalCarbs = (state.data.calories?.todayLog?.meals||[]).reduce((s,m)=>s+(m.carbs||0),0) || 45;
      const totalFat = (state.data.calories?.todayLog?.meals||[]).reduce((s,m)=>s+(m.fat||0),0) || 20;
      createChart('macroChart', { type:'doughnut', data:{ labels:['Protein','Carbs','Fat'], datasets:[{ data:[totalProtein,totalCarbs,totalFat], backgroundColor:['#059669','#3b82f6','#eab308'], borderWidth:0 }] }, options:{ responsive:true, cutout:'60%', plugins:{ legend:{ position:'bottom', labels:{ usePointStyle:true, padding:12, font:{family:'Inter',size:12} } } } } });
    }

    async function loadCalorieData() { try { const todayLog = await api('/calories/today'); state.data.calories = { todayLog }; const el = document.getElementById('page-content'); if (el && state.page==='calories') { el.innerHTML=renderCalories(); lucide.createIcons(); initCalorieCharts(); } } catch(err){} }

    // ============================================================
    // FOOD SEARCH MODAL
    // ============================================================
    function openFoodSearch(mealType) {
      state.foodSearchMealType = mealType;
      state.foodSearchQuery = '';
      state.foodSearchTab = 'library';
      showModal(renderFoodSearchModal());
    }

    function renderFoodSearchModal() {
      const query = state.foodSearchQuery.toLowerCase();
      let results = [];

      if (state.foodSearchTab === 'library') {
        results = query ? FOOD_DATABASE.filter(f => f.name.toLowerCase().includes(query)) : FOOD_DATABASE.slice(0, 30);
      } else if (state.foodSearchTab === 'myfoods') {
        results = query ? state.myFoods.filter(f => f.name.toLowerCase().includes(query)) : state.myFoods;
      } else if (state.foodSearchTab === 'myrecipes') {
        results = query ? state.myRecipes.filter(f => f.name.toLowerCase().includes(query)) : state.myRecipes;
      }

      const mealLabels = {breakfast:'Breakfast',lunch:'Lunch',dinner:'Dinner',snack:'Snack'};

      return `
        <div class="flex flex-col max-h-[85vh]">
          <!-- Header -->
          <div class="bg-brand-600 text-white p-5 rounded-t-2xl">
            <div class="flex items-center justify-between mb-4">
              <h3 class="font-bold text-lg">Add Food — ${mealLabels[state.foodSearchMealType] || 'Meal'}</h3>
              <button onclick="closeModal()" class="text-white/70 hover:text-white"><i data-lucide="x" class="w-5 h-5"></i></button>
            </div>
            <div class="relative">
              <i data-lucide="search" class="w-4 h-4 text-white/50 absolute left-3 top-1/2 -translate-y-1/2"></i>
              <input type="text" id="food-search-input" value="${state.foodSearchQuery}" oninput="handleFoodSearch(this.value)" placeholder="Search foods..." class="w-full pl-10 pr-4 py-3 bg-white/15 border border-white/20 rounded-xl text-white placeholder-white/50 focus:ring-2 focus:ring-white/30 outline-none text-sm" autofocus>
            </div>
          </div>

          <!-- Tabs -->
          <div class="flex border-b border-slate-200 px-5 pt-3">
            <button onclick="switchFoodTab('library')" class="px-4 pb-3 text-sm ${state.foodSearchTab==='library'?'tab-active':'tab-inactive'}">Library</button>
            <button onclick="switchFoodTab('myfoods')" class="px-4 pb-3 text-sm ${state.foodSearchTab==='myfoods'?'tab-active':'tab-inactive'}">My Foods</button>
            <button onclick="switchFoodTab('myrecipes')" class="px-4 pb-3 text-sm ${state.foodSearchTab==='myrecipes'?'tab-active':'tab-inactive'}">My Recipes</button>
          </div>

          <!-- Results -->
          <div class="flex-1 overflow-y-auto p-4 space-y-1.5" style="max-height:400px;">
            ${results.length === 0 ? '<p class="text-center text-slate-400 text-sm py-8">No foods found. Try a different search.</p>' : results.map(food => `
              <div class="food-item flex items-center justify-between p-3.5 rounded-xl cursor-pointer transition-all border border-transparent hover:border-brand-200" onclick="addFoodToMeal(${JSON.stringify(food).replace(/"/g, '&quot;')})">
                <div class="flex-1 min-w-0 mr-3">
                  <p class="text-sm font-semibold text-slate-800 truncate">${food.name}</p>
                  <p class="text-[11px] text-slate-400">${food.serving || ''}</p>
                </div>
                <div class="flex items-center gap-3">
                  <div class="text-right">
                    <p class="text-xs text-slate-500"><span class="text-blue-500 font-semibold">C:${food.carbs}g</span> <span class="text-brand-500 font-semibold">P:${food.protein}g</span> <span class="text-yellow-500 font-semibold">F:${food.fat}g</span></p>
                    <p class="text-xs font-bold text-slate-700">${food.calories} kcal</p>
                  </div>
                  <div class="w-8 h-8 bg-brand-50 rounded-full flex items-center justify-center text-brand-600 hover:bg-brand-100 transition-all flex-shrink-0">
                    <i data-lucide="plus" class="w-4 h-4"></i>
                  </div>
                </div>
              </div>
            `).join('')}
          </div>

          <!-- Add Custom Food -->
          <div class="border-t border-slate-200 p-4">
            <button onclick="showAddCustomFood()" class="w-full flex items-center justify-center gap-2 py-2.5 border-2 border-dashed border-slate-200 rounded-xl text-slate-500 hover:text-brand-600 hover:border-brand-300 text-sm font-medium transition-all">
              <i data-lucide="plus" class="w-4 h-4"></i> Add custom food
            </button>
          </div>
        </div>`;
    }

    function handleFoodSearch(query) {
      state.foodSearchQuery = query;
      const root = document.getElementById('modal-root');
      if (root) {
        root.querySelector('.slide-up').innerHTML = renderFoodSearchModal();
        lucide.createIcons();
        setTimeout(() => {
          const input = document.getElementById('food-search-input');
          if (input) { input.focus(); input.setSelectionRange(input.value.length, input.value.length); }
        }, 50);
      }
    }

    function switchFoodTab(tab) {
      state.foodSearchTab = tab;
      handleFoodSearch(state.foodSearchQuery);
    }

    async function addFoodToMeal(food) {
      const mealEntry = {
        name: food.name,
        calories: food.calories,
        protein: food.protein,
        carbs: food.carbs,
        fat: food.fat,
        mealType: state.foodSearchMealType
      };
      try {
        await api('/calories/log','POST', mealEntry);
        showToast(`${food.name} added!`);
        closeModal();
        loadCalorieData();
      } catch(err) {
        // Fallback: add locally
        if (!state.data.calories) state.data.calories = { todayLog: {meals:[], totalCalories:0} };
        if (!state.data.calories.todayLog) state.data.calories.todayLog = {meals:[], totalCalories:0};
        state.data.calories.todayLog.meals.push(mealEntry);
        state.data.calories.todayLog.totalCalories = state.data.calories.todayLog.meals.reduce((s,m)=>s+m.calories,0);
        closeModal();
        const el = document.getElementById('page-content');
        if (el && state.page==='calories') { el.innerHTML=renderCalories(); lucide.createIcons(); initCalorieCharts(); }
        showToast(`${food.name} added!`);
      }
    }

    function showAddCustomFood() {
      showModal(renderAddCustomFoodModal());
    }

    function renderAddCustomFoodModal() {
      return `
        <div class="p-6">
          <div class="flex items-center justify-between mb-6">
            <h2 class="text-xl font-bold text-slate-900">Add Custom Food</h2>
            <button onclick="closeModal()" class="text-slate-400 hover:text-slate-600"><i data-lucide="x" class="w-5 h-5"></i></button>
          </div>
          <form onsubmit="saveCustomFood(event)" class="space-y-4">
            <div><label class="block text-sm font-medium text-slate-700 mb-1.5">Food Name</label><input type="text" id="custom-food-name" required placeholder="e.g. My Granola Bar" class="w-full px-4 py-3 border border-slate-200 rounded-lg focus:ring-2 focus:ring-brand-500 outline-none"></div>
            <div><label class="block text-sm font-medium text-slate-700 mb-1.5">Serving Size</label><input type="text" id="custom-food-serving" placeholder="e.g. 1 bar (45g)" class="w-full px-4 py-3 border border-slate-200 rounded-lg focus:ring-2 focus:ring-brand-500 outline-none"></div>
            <div class="grid grid-cols-2 gap-3">
              <div><label class="block text-sm font-medium text-slate-700 mb-1.5">Calories (kcal)</label><input type="number" id="custom-food-cal" required min="0" placeholder="0" class="w-full px-4 py-3 border border-slate-200 rounded-lg focus:ring-2 focus:ring-brand-500 outline-none"></div>
              <div><label class="block text-sm font-medium text-slate-700 mb-1.5">Protein (g)</label><input type="number" id="custom-food-protein" min="0" step="0.1" placeholder="0" class="w-full px-4 py-3 border border-slate-200 rounded-lg focus:ring-2 focus:ring-brand-500 outline-none"></div>
              <div><label class="block text-sm font-medium text-slate-700 mb-1.5">Carbs (g)</label><input type="number" id="custom-food-carbs" min="0" step="0.1" placeholder="0" class="w-full px-4 py-3 border border-slate-200 rounded-lg focus:ring-2 focus:ring-brand-500 outline-none"></div>
              <div><label class="block text-sm font-medium text-slate-700 mb-1.5">Fat (g)</label><input type="number" id="custom-food-fat" min="0" step="0.1" placeholder="0" class="w-full px-4 py-3 border border-slate-200 rounded-lg focus:ring-2 focus:ring-brand-500 outline-none"></div>
            </div>
            <button type="submit" class="w-full bg-brand-600 hover:bg-brand-700 text-white py-3.5 rounded-lg font-semibold shadow-md transition-all">Save & Add to My Foods</button>
          </form>
        </div>`;
    }

    function saveCustomFood(e) {
      e.preventDefault();
      const food = {
        id: Date.now(),
        name: document.getElementById('custom-food-name').value,
        serving: document.getElementById('custom-food-serving').value || '1 serving',
        calories: parseInt(document.getElementById('custom-food-cal').value) || 0,
        protein: parseFloat(document.getElementById('custom-food-protein').value) || 0,
        carbs: parseFloat(document.getElementById('custom-food-carbs').value) || 0,
        fat: parseFloat(document.getElementById('custom-food-fat').value) || 0,
        category: 'Custom'
      };
      state.myFoods.push(food);
      localStorage.setItem('fh_myfoods', JSON.stringify(state.myFoods));
      closeModal();
      showToast('Custom food saved!');
      openFoodSearch(state.foodSearchMealType);
    }

    // ============================================================
    // ADD RECIPE MODAL
    // ============================================================
    function openAddRecipe() {
      state.recipeIngredients = [];
      showModal(renderAddRecipeModal());
    }

    function renderAddRecipeModal() {
      return `
        <div class="p-6">
          <div class="flex items-center justify-between mb-6">
            <h2 class="text-xl font-bold text-slate-900">Create New Recipe</h2>
            <button onclick="closeModal()" class="text-slate-400 hover:text-slate-600"><i data-lucide="x" class="w-5 h-5"></i></button>
          </div>
          <form onsubmit="saveRecipe(event)" class="space-y-4">
            <div><label class="block text-sm font-medium text-slate-700 mb-1.5">Recipe Name</label><input type="text" id="recipe-name" required placeholder="e.g. Protein Power Bowl" class="w-full px-4 py-3 border border-slate-200 rounded-lg focus:ring-2 focus:ring-brand-500 outline-none"></div>
            <div><label class="block text-sm font-medium text-slate-700 mb-1.5">Servings</label><input type="number" id="recipe-servings" value="1" min="1" class="w-full px-4 py-3 border border-slate-200 rounded-lg focus:ring-2 focus:ring-brand-500 outline-none"></div>

            <!-- Ingredients -->
            <div>
              <label class="block text-sm font-medium text-slate-700 mb-2">Ingredients</label>
              <div class="relative mb-3">
                <input type="text" id="recipe-ingr-search" oninput="searchRecipeIngr(this.value)" placeholder="Search ingredient..." class="w-full px-4 py-3 border border-slate-200 rounded-lg focus:ring-2 focus:ring-brand-500 outline-none text-sm">
                <div id="recipe-ingr-results" class="absolute top-full left-0 right-0 bg-white border border-slate-200 rounded-lg mt-1 max-h-40 overflow-y-auto z-10 shadow-lg hidden"></div>
              </div>
              <div id="recipe-ingredients-list" class="space-y-2">
                ${state.recipeIngredients.map((ing, i) => `
                  <div class="flex items-center justify-between bg-slate-50 rounded-lg px-3 py-2">
                    <div><p class="text-sm font-medium text-slate-700">${ing.name}</p><p class="text-[10px] text-slate-400">${ing.calories} kcal · C:${ing.carbs}g P:${ing.protein}g F:${ing.fat}g</p></div>
                    <button type="button" onclick="removeRecipeIngredient(${i})" class="text-slate-400 hover:text-red-500"><i data-lucide="x" class="w-4 h-4"></i></button>
                  </div>
                `).join('')}
              </div>
            </div>

            <!-- Recipe Totals -->
            ${state.recipeIngredients.length > 0 ? `
            <div class="bg-brand-50 rounded-xl p-4">
              <p class="text-xs text-brand-600 font-bold mb-2 uppercase">Recipe Totals (per serving)</p>
              <div class="grid grid-cols-4 gap-3 text-center">
                <div><p class="text-lg font-bold text-slate-900">${Math.round(state.recipeIngredients.reduce((s,i)=>s+i.calories,0)/parseInt(document.getElementById('recipe-servings')?.value||1))}</p><p class="text-[10px] text-slate-400">kcal</p></div>
                <div><p class="text-lg font-bold text-blue-600">${Math.round(state.recipeIngredients.reduce((s,i)=>s+i.carbs,0)*10/parseInt(document.getElementById('recipe-servings')?.value||1))/10}</p><p class="text-[10px] text-slate-400">Carbs</p></div>
                <div><p class="text-lg font-bold text-brand-600">${Math.round(state.recipeIngredients.reduce((s,i)=>s+i.protein,0)*10/parseInt(document.getElementById('recipe-servings')?.value||1))/10}</p><p class="text-[10px] text-slate-400">Protein</p></div>
                <div><p class="text-lg font-bold text-yellow-600">${Math.round(state.recipeIngredients.reduce((s,i)=>s+i.fat,0)*10/parseInt(document.getElementById('recipe-servings')?.value||1))/10}</p><p class="text-[10px] text-slate-400">Fat</p></div>
              </div>
            </div>` : ''}

            <div><label class="block text-sm font-medium text-slate-700 mb-1.5">Instructions (optional)</label><textarea id="recipe-instructions" rows="3" placeholder="Cooking steps..." class="w-full px-4 py-3 border border-slate-200 rounded-lg focus:ring-2 focus:ring-brand-500 outline-none text-sm resize-none"></textarea></div>
            <button type="submit" class="w-full bg-brand-600 hover:bg-brand-700 text-white py-3.5 rounded-lg font-semibold shadow-md transition-all">Save Recipe</button>
          </form>
        </div>`;
    }

    function searchRecipeIngr(query) {
      const container = document.getElementById('recipe-ingr-results');
      if (!query || query.length < 2) { container.classList.add('hidden'); return; }
      const results = FOOD_DATABASE.filter(f => f.name.toLowerCase().includes(query.toLowerCase())).slice(0, 8);
      if (results.length === 0) { container.innerHTML = '<p class="p-3 text-sm text-slate-400">No results</p>'; container.classList.remove('hidden'); return; }
      container.innerHTML = results.map(f => `
        <button type="button" onclick="addRecipeIngredient(${f.id})" class="w-full text-left px-3 py-2.5 hover:bg-brand-50 flex items-center justify-between transition-all border-b border-slate-50 last:border-0">
          <div><p class="text-sm font-medium text-slate-700">${f.name}</p><p class="text-[10px] text-slate-400">${f.serving}</p></div>
          <span class="text-xs font-semibold text-slate-500">${f.calories} kcal</span>
        </button>
      `).join('');
      container.classList.remove('hidden');
    }

    function addRecipeIngredient(foodId) {
      const food = FOOD_DATABASE.find(f => f.id === foodId);
      if (food && !state.recipeIngredients.find(i => i.id === food.id)) {
        state.recipeIngredients.push({...food});
        const modal = document.querySelector('.slide-up');
        if (modal) { modal.innerHTML = renderAddRecipeModal(); lucide.createIcons(); }
      }
      document.getElementById('recipe-ingr-results').classList.add('hidden');
      document.getElementById('recipe-ingr-search').value = '';
    }

    function removeRecipeIngredient(idx) {
      state.recipeIngredients.splice(idx, 1);
      const modal = document.querySelector('.slide-up');
      if (modal) { modal.innerHTML = renderAddRecipeModal(); lucide.createIcons(); }
    }

    function saveRecipe(e) {
      e.preventDefault();
      if (state.recipeIngredients.length === 0) { showToast('Add at least one ingredient', 'error'); return; }
      const servings = parseInt(document.getElementById('recipe-servings').value) || 1;
      const recipe = {
        id: Date.now(),
        name: document.getElementById('recipe-name').value,
        servings,
        serving: `1 serving`,
        calories: Math.round(state.recipeIngredients.reduce((s,i)=>s+i.calories,0)/servings),
        protein: Math.round(state.recipeIngredients.reduce((s,i)=>s+i.protein,0)/servings*10)/10,
        carbs: Math.round(state.recipeIngredients.reduce((s,i)=>s+i.carbs,0)/servings*10)/10,
        fat: Math.round(state.recipeIngredients.reduce((s,i)=>s+i.fat,0)/servings*10)/10,
        ingredients: [...state.recipeIngredients],
        instructions: document.getElementById('recipe-instructions').value,
        category: 'Recipe'
      };
      state.myRecipes.push(recipe);
      localStorage.setItem('fh_recipes', JSON.stringify(state.myRecipes));
      closeModal();
      showToast('Recipe saved!');
    }

    // ============================================================
    // WEIGHT
    // ============================================================
    function renderWeight() {
      loadWeightData();
      const history = state.data.weight?.history || [];
      const curWeight = history.length ? history[history.length-1].weight : '--';
      return `<div class="mb-8"><h1 class="text-3xl font-bold text-slate-900 tracking-tight">Weight Tracker</h1></div><div class="bg-white rounded-2xl p-6 shadow-sm border border-slate-100 mb-6"><h3 class="text-lg font-bold text-slate-900 mb-5">Log Weight</h3><form onsubmit="handleWeightLog(event)" class="grid sm:grid-cols-3 gap-4"><input type="number" id="weight-val" step="0.1" min="20" required placeholder="Weight (kg)" class="px-4 py-3 border border-slate-200 rounded-lg focus:ring-2 focus:ring-brand-500 outline-none"><input type="date" id="weight-date" value="${new Date().toISOString().split('T')[0]}" class="px-4 py-3 border border-slate-200 rounded-lg focus:ring-2 focus:ring-brand-500 outline-none"><button type="submit" class="bg-brand-600 hover:bg-brand-700 text-white py-3 rounded-lg font-semibold shadow-md transition-all">Save</button></form></div><div class="bg-white rounded-2xl p-6 shadow-sm border border-slate-100"><h3 class="text-lg font-bold text-slate-900 mb-4">Weight History</h3><canvas id="weightChart" height="220"></canvas></div>`;
    }

    function initWeightChart() {
